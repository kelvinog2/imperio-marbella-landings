---
import LandingPage from "@/components/LandingPage.astro";
import { baseUrl } from "@/data/landings";
import { getApartmentPageContent } from "@/lib/content";
import { buildJsonLd } from "@/lib/jsonld";
import BaseLayout from "@/layouts/BaseLayout.astro";

const { apartment, apartmentCards, directBenefits, landing, promo, whatsappHref } = await getApartmentPageContent("imperio-2");
const canonical = `${baseUrl}/${landing.slug}/`;
const image = new URL(landing.heroImage, baseUrl).toString();
---

<BaseLayout
  title={landing.title}
  description={landing.metaDescription}
  canonical={canonical}
  image={image}
  jsonLd={buildJsonLd(landing, apartment)}
>
  <LandingPage
    apartment={apartment}
    apartmentCards={apartmentCards}
    directBenefits={directBenefits}
    landing={landing}
    promo={promo}
    whatsappHref={whatsappHref}
  />
</BaseLayout>
