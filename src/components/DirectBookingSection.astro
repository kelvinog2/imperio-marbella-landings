---
import { directBenefits as defaultDirectBenefits, promo as defaultPromo, type Apartment } from "@/data/landings";
import { buildWhatsappHref } from "@/lib/whatsapp";
import DirectBenefitFlow from "./DirectBenefitFlow";

interface Props {
  compact?: boolean;
  apartment?: Apartment;
  promo?: typeof defaultPromo;
  directBenefits?: typeof defaultDirectBenefits | { title: string; text: string }[];
  whatsappHref?: string;
}

const {
  compact = false,
  apartment,
  promo = defaultPromo,
  directBenefits = defaultDirectBenefits,
  whatsappHref
} = Astro.props;
const targetName = apartment?.shortName ?? "Apartamentos Imperio";
const bookingUrl = apartment?.bookingUrl ?? "/#apartamentos";
const bookingLabel = apartment ? "Comparar en Booking.com" : "Ver apartamentos";
const bookingIsExternal = bookingUrl.startsWith("http");
const whatsappMessage = apartment ? `${promo.whatsappMessage}${apartment.shortName}. ` : promo.whatsappMessage;
const directWhatsappHref = whatsappHref ?? buildWhatsappHref(apartment?.phone, whatsappMessage);
---

<section class:list={["direct-booking", compact && "direct-booking-compact"]} id="reserva-directa" aria-labelledby="direct-booking-title">
  <div class="direct-booking-inner direct-booking-simple">
    <div class="direct-copy">
      <span class="section-kicker">{promo.label}</span>
      <h2 id="direct-booking-title">{promo.title}</h2>
      <p>{promo.text}</p>
      <div class="direct-actions">
        <a class="button button-primary" href={directWhatsappHref}>Solicitar precio especial por WhatsApp</a>
        <a
          class="button button-outline"
          href={bookingUrl}
          target={bookingIsExternal ? "_blank" : undefined}
          rel={bookingIsExternal ? "noreferrer" : undefined}
        >
          {bookingLabel}
        </a>
      </div>
    </div>

    <aside class="direct-instruction-card" aria-label={`Pasos para solicitar precio especial en ${targetName}`}>
      <span>Como funciona</span>
      <ol class="direct-steps">
        <li>Elige el apartamento que mas encaja contigo.</li>
        <li>Escribenos por WhatsApp con el codigo de tu tarjeta.</li>
        <li>Indica fechas, huespedes y dudas. Te respondemos con tarifa directa.</li>
      </ol>
    </aside>

    <DirectBenefitFlow client:visible benefits={directBenefits} />
  </div>
</section>
