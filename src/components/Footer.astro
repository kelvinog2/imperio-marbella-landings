---
import { apartmentCards, whatsappHref } from "@/data/landings";
---

<footer class="footer" id="contacto">
  <div class="footer-brand">
    <img src="/assets/apartamento/imperio-logo.png" alt="" width="84" height="45" loading="lazy" />
    <div>
      <strong>Apartamentos Imperio</strong>
      <p>Reserva directa en Marbella centro, Playa de Venus y Puerto Deportivo.</p>
    </div>
  </div>

  <nav class="footer-links" aria-label="Páginas de Apartamentos Imperio">
    <a href="/">Inicio</a>
    {apartmentCards.map((item) => <a href={item.href}>{item.name}</a>)}
    <a href="/#reserva-directa">Reserva directa</a>
    <a href={whatsappHref}>WhatsApp</a>
  </nav>
</footer>
