---
import { apartment as defaultApartment, type Apartment } from "@/data/landings";

interface Props {
  apartment?: Apartment;
}

const { apartment = defaultApartment } = Astro.props;
---

<section class="section" id="servicios">
  <div class="section-narrow">
    <div class="section-header">
      <div>
        <span class="section-kicker">Incluido</span>
        <h2 class="section-title">Todo lo que evita compras de ultimo minuto.</h2>
      </div>
      <p class="section-copy">
        Servicios claros para llegar, dejar las maletas y empezar Marbella sin gestiones innecesarias.
      </p>
    </div>
    <div class="service-grid">
      {apartment.services.map((service) => (
        <div class="service-item">
          <svg aria-hidden="true" width="24" height="24" viewBox="0 0 24 24" fill="none">
            <path d="M12 3.5l2.5 5.1 5.6.8-4 3.9.9 5.5-5-2.7-5 2.7.9-5.5-4-3.9 5.6-.8L12 3.5z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round" />
          </svg>
          <span>{service}</span>
        </div>
      ))}
    </div>
  </div>
</section>
