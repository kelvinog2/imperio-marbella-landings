---
import { apartment as defaultApartment, type Apartment } from "@/data/landings";
import ReviewProofCards from "./ReviewProofCards";

interface Props {
  apartment?: Apartment;
}

const { apartment = defaultApartment } = Astro.props;
const reviewImages = apartment.gallery.flatMap((group) => group.images).slice(0, 4);
---

<section class="section reviews-section" aria-labelledby="reviews-title">
  <div class="section-narrow">
    <div class="section-header reviews-header">
      <div>
        <span class="section-kicker">Comentarios 10/10</span>
        <h2 class="section-title" id="reviews-title">Lo que dicen huéspedes reales en Booking.com.</h2>
      </div>
      <p class="section-copy">
        Reseñas reales que destacan ubicación, limpieza, equipamiento y trato directo.
      </p>
    </div>
    <ReviewProofCards client:visible reviews={apartment.reviews} images={reviewImages} />
  </div>
</section>
