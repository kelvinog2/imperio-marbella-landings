---
import { apartment, apartmentCards, directBenefits, mainLanding, whatsappHref } from "@/data/landings";
import DirectBookingSection from "./DirectBookingSection.astro";
import Footer from "./Footer.astro";
import Hero from "./Hero.astro";
import LocationExplorer from "./LocationExplorer";
import SiteHeader from "./SiteHeader.astro";

const navItems = [
  { label: "Inicio", href: "/" },
  { label: "Imperio 1", href: "/imperio-1/" },
  { label: "Imperio 2", href: "/imperio-2/" },
  { label: "Imperio 3", href: "/imperio-3/" },
  { label: "Reserva directa", href: "#reserva-directa" }
];

const galleryItems = [
  {
    image: "/assets/main-gallery/gallery-01.webp",
    apartment: "Imperio 1",
    label: "Salón con terraza",
    variant: "tile-large"
  },
  {
    image: "/assets/main-gallery/gallery-02.webp",
    apartment: "Imperio 2",
    label: "125 m2 en Marbella centro",
    variant: "tile-wide"
  },
  {
    image: "/assets/main-gallery/gallery-03.webp",
    apartment: "Imperio 3",
    label: "Puerto deportivo y playa",
    variant: "tile-tall"
  },
  {
    image: "/assets/main-gallery/gallery-04.webp",
    apartment: "Imperio 1",
    label: "Dormitorio preparado",
    variant: "tile-small"
  },
  {
    image: "/assets/main-gallery/gallery-05.webp",
    apartment: "Imperio 2",
    label: "Jacuzzi y descanso",
    variant: "tile-small"
  },
  {
    image: "/assets/main-gallery/gallery-06.webp",
    apartment: "Imperio 3",
    label: "Interior práctico",
    variant: "tile-small"
  },
  {
    image: "/assets/main-gallery/gallery-07.webp",
    apartment: "Imperio 1",
    label: "Cocina equipada",
    variant: "tile-wide"
  },
  {
    image: "/assets/main-gallery/gallery-08.webp",
    apartment: "Imperio 2",
    label: "Terraza y luz",
    variant: "tile-small mobile-soft-hide"
  },
  {
    image: "/assets/main-gallery/gallery-09.webp",
    apartment: "Imperio 3",
    label: "Balcón junto al mar",
    variant: "tile-small mobile-soft-hide"
  }
];
---

<main class="page-shell main-landing-shell">
  <SiteHeader navItems={navItems} ctaHref="#reserva-directa" ctaLabel="Descuento" />
  <Hero landing={mainLanding} />

  <section class="main-proof-band" aria-label="Promoción de reserva directa">
    <div class="main-proof-inner">
      <div class="booking-style-badge">
        <span>Booking.com</span>
        <strong>9,9</strong>
        <em>Excepcional</em>
      </div>
      <p>
        Apartamentos Imperio reúne estancias con valoración excepcional en Marbella. Si llegaste por
        una tarjeta especial, puedes generar tu descuento directo una sola vez y usarlo en cualquiera
        de las páginas.
      </p>
      <a class="button button-primary" href="#reserva-directa">Generar descuento</a>
    </div>
  </section>

  <section class="main-apartments" id="apartamentos" aria-labelledby="apartments-title">
    <div class="main-section-heading">
      <span>Nuestros apartamentos</span>
      <h2 id="apartments-title">Elige tu Imperio en Marbella</h2>
      <p>Compara rápido, contacta directamente y reserva con una ventaja que no aparece en los portales.</p>
    </div>

    <div class="apartment-card-grid">
      {apartmentCards.map((item) => (
        <article class="apartment-card">
          <div class="apartment-card-media">
            <img src={item.image} alt={`${item.name}, ${item.subtitle}`} width="640" height="480" loading="lazy" decoding="async" />
            <div class="booking-rating-card" role="img" aria-label={`Booking.com: ${item.rating} excepcional para ${item.name}`}>
              <span>Booking.com</span>
              <strong>{item.rating}</strong>
              <em>Excepcional</em>
            </div>
          </div>
          <div class="apartment-card-body">
            <span>{item.subtitle}</span>
            <h3>{item.name}</h3>
            <p>{item.description}</p>
            <ul>
              {item.facts.map((fact) => <li>{fact}</li>)}
            </ul>
            <div class="apartment-card-actions">
              <a class="button button-primary" href={item.href} aria-label={`Ver detalles de ${item.name}`}>Ver detalles</a>
              <a
                class="button button-blue"
                href={item.bookingHref}
                aria-label={`Ver reseñas de ${item.name} en Booking.com`}
                target={item.bookingHref.startsWith("http") ? "_blank" : undefined}
                rel={item.bookingHref.startsWith("http") ? "noreferrer" : undefined}
              >
                Ver reseñas
              </a>
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>

  <LocationExplorer client:visible />

  <section class="direct-benefits-mini" aria-labelledby="benefits-title">
    <div class="main-section-heading">
      <span>Beneficios de reservar directo</span>
      <h2 id="benefits-title">Tu código convierte una consulta en una tarifa especial</h2>
    </div>
    <div class="direct-benefit-grid">
      {directBenefits.map((benefit) => (
        <article>
          <span aria-hidden="true"></span>
          <h3>{benefit.title}</h3>
          <p>{benefit.text}</p>
        </article>
      ))}
    </div>
  </section>

  <DirectBookingSection compact />

  <section class="main-gallery" id="galeria" aria-labelledby="main-gallery-title">
    <div class="main-section-heading">
      <span>Galería de la experiencia Marbella</span>
      <h2 id="main-gallery-title">Mar, centro y apartamentos listos para llegar</h2>
    </div>
    <div class="main-gallery-mosaic">
      {galleryItems.map((item) => (
        <figure class:list={["main-gallery-tile", item.variant]}>
          <img src={item.image} alt={`${item.apartment}: ${item.label}`} width="720" height="520" loading="lazy" decoding="async" />
          <figcaption>
            <span>{item.apartment}</span>
            <strong>{item.label}</strong>
          </figcaption>
        </figure>
      ))}
    </div>
  </section>

  <section class="main-contact-strip">
    <div>
      <span>{apartment.brand}</span>
      <strong>Reserva directa para Marbella</strong>
    </div>
    <a class="button button-light" href={whatsappHref}>Contactar por WhatsApp</a>
  </section>

  <Footer />
</main>
