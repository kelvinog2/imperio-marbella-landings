---
import { apartment, apartmentCards, mainLanding, whatsappHref } from "@/data/landings";
import DirectBookingSection from "./DirectBookingSection.astro";
import Footer from "./Footer.astro";
import Hero from "./Hero.astro";
import SiteHeader from "./SiteHeader.astro";

const navItems = [
  { label: "Inicio", href: "/" },
  { label: "Imperio 1", href: "/imperio-1/" },
  { label: "Imperio 2", href: "/imperio-2/" },
  { label: "Imperio 3", href: "/imperio-3/" },
  { label: "Reserva directa", href: "#reserva-directa" }
];

const apartmentGalleryGroups = [
  {
    id: "main-gallery-imperio-1",
    name: "Imperio 1",
    subtitle: "Centro, terraza y parking",
    href: "/imperio-1/",
    images: [
      { src: "/assets/main-gallery/gallery-01.webp", label: "Salón con terraza", featured: true },
      { src: "/assets/main-gallery/gallery-04.webp", label: "Dormitorio preparado" },
      { src: "/assets/main-gallery/gallery-07.webp", label: "Cocina equipada" }
    ]
  },
  {
    id: "main-gallery-imperio-2",
    name: "Imperio 2",
    subtitle: "125 m2, jacuzzi y luz",
    href: "/imperio-2/",
    images: [
      { src: "/assets/main-gallery/gallery-02.webp", label: "Apartamento amplio", featured: true },
      { src: "/assets/main-gallery/gallery-05.webp", label: "Jacuzzi y descanso" },
      { src: "/assets/main-gallery/gallery-08.webp", label: "Terraza y luz" }
    ]
  },
  {
    id: "main-gallery-imperio-3",
    name: "Imperio 3",
    subtitle: "Puerto deportivo y playa",
    href: "/imperio-3/",
    images: [
      { src: "/assets/main-gallery/gallery-03.webp", label: "Junto al puerto", featured: true },
      { src: "/assets/main-gallery/gallery-06.webp", label: "Interior práctico" },
      { src: "/assets/main-gallery/gallery-09.webp", label: "Balcón junto al mar" }
    ]
  }
];
---

<main class="page-shell main-landing-shell">
  <SiteHeader navItems={navItems} ctaHref={whatsappHref} ctaLabel="WhatsApp" />
  <Hero landing={mainLanding} />

  <section class="main-proof-band" aria-label="Promoción de reserva directa">
    <div class="main-proof-inner">
      <div class="booking-style-badge">
        <span>Booking.com</span>
        <strong>9,9</strong>
        <em>Excepcional</em>
      </div>
      <p>
        Has llegado a la colección Imperio. Si tienes una tarjeta promocional, escríbenos por
        WhatsApp con tu código, fechas y número de huéspedes. Te responderemos con precio especial
        de reserva directa.
      </p>
      <a class="button button-primary" href={whatsappHref}>Solicitar precio especial</a>
    </div>
  </section>

  <section class="main-apartments" id="apartamentos" aria-labelledby="apartments-title">
    <div class="main-section-heading">
      <span>Nuestros apartamentos</span>
      <h2 id="apartments-title">Elige tu Imperio en Marbella</h2>
      <p>Compara rápido, abre la ficha que te guste y contacta por WhatsApp para recibir tu tarifa directa.</p>
    </div>

    <div class="apartment-card-grid">
      {apartmentCards.map((item) => (
        <article class="apartment-card">
          <div class="apartment-card-media">
            <img src={item.image} alt={`${item.name}, ${item.subtitle}`} width="640" height="480" loading="lazy" decoding="async" />
            <div class="booking-rating-card" role="img" aria-label={`Booking.com: ${item.rating} excepcional para ${item.name}`}>
              <span>Booking.com</span>
              <strong>{item.rating}</strong>
              <em>Excepcional</em>
            </div>
          </div>
          <div class="apartment-card-body">
            <span>{item.subtitle}</span>
            <h3>{item.name}</h3>
            <p>{item.description}</p>
            <ul>
              {item.facts.map((fact) => <li>{fact}</li>)}
            </ul>
            <div class="apartment-card-actions">
              <a class="button button-primary" href={item.href} aria-label={`Ver detalles de ${item.name}`}>Ver detalles</a>
              <a
                class="button button-blue"
                href={item.bookingHref}
                aria-label={`Ver reseñas de ${item.name} en Booking.com`}
                target={item.bookingHref.startsWith("http") ? "_blank" : undefined}
                rel={item.bookingHref.startsWith("http") ? "noreferrer" : undefined}
              >
                Ver reseñas
              </a>
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="main-gallery" id="galeria" aria-labelledby="main-gallery-title">
    <div class="main-section-heading">
      <span>Elige tu estancia</span>
      <h2 id="main-gallery-title">Tres formas de vivir Marbella, una tarifa especial directa</h2>
      <p>Descubre cuál encaja con tu viaje: terraza en el centro, amplitud con jacuzzi o puerto deportivo junto al mar.</p>
    </div>

    <div class="apartment-gallery-tabs">
      {apartmentGalleryGroups.map((group, index) => (
        <input
          class="apartment-gallery-radio"
          type="radio"
          name="main-apartment-gallery"
          id={group.id}
          checked={index === 0}
        />
      ))}

      <div class="apartment-gallery-controls" aria-label="Seleccionar galería de apartamento">
        {apartmentGalleryGroups.map((group) => (
          <label class="apartment-gallery-tab" for={group.id}>
            <strong>{group.name}</strong>
            <span>{group.subtitle}</span>
          </label>
        ))}
      </div>

      <div class="apartment-gallery-panels">
        {apartmentGalleryGroups.map((group) => (
          <article class="apartment-gallery-panel">
            <div class="apartment-gallery-panel-copy">
              <span>{group.subtitle}</span>
              <h3>{group.name}</h3>
              <p>Explora sus espacios clave y entra en la ficha para ver más fotos, detalles y solicitar tu precio especial por WhatsApp.</p>
              <a class="button button-primary" href={group.href}>Ver {group.name}</a>
            </div>
            <div class="apartment-gallery-grid">
              {group.images.map((image) => (
                <figure class:list={["apartment-gallery-shot", image.featured && "is-featured"]}>
                  <img src={image.src} alt={`${group.name}: ${image.label}`} width="780" height="560" loading="lazy" decoding="async" />
                  <figcaption>{image.label}</figcaption>
                </figure>
              ))}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <DirectBookingSection compact />

  <section class="main-contact-strip">
    <div>
      <span>{apartment.brand}</span>
      <strong>Reserva directa para Marbella</strong>
    </div>
    <a class="button button-light" href={whatsappHref}>Contactar por WhatsApp</a>
  </section>

  <Footer />
</main>
